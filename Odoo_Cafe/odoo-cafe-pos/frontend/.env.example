# Odoo Cafe POS - Frontend Environment Configuration
# Copy this file to .env.local and adjust values for your environment

# API Configuration
# In development: http://localhost:8000 (default backend port)
# In production: adjust to your backend URL
REACT_APP_API_URL=http://localhost:8000

# Application Settings
REACT_APP_APP_NAME=Odoo Cafe POS
REACT_APP_APP_VERSION=1.0.0

# Feature Flags (optional, for future use)
REACT_APP_ENABLE_SELF_ORDER=true
REACT_APP_ENABLE_KDS=true
REACT_APP_ENABLE_REPORTS=true

# Logging
REACT_APP_LOG_LEVEL=info
